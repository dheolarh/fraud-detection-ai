# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fraud_db

# Redis Configuration (Optional - for TransactionSpikeLogic)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Banking Backend API
BANKING_API_URL=http://localhost:8001

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development

# ML Models
MODEL_PATH=./models
RETRAIN_INTERVAL_DAYS=30

# Fraud Detection Configuration
RULE_WEIGHT=0.6
ML_WEIGHT=0.4

# Logging
LOG_LEVEL=INFO
LOG_FILE=fraud_detection.log
